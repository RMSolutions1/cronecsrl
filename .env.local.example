# Copia este archivo a .env.local (desarrollo) o configura en tu plataforma (Vercel, etc.) en producción.
# No subas .env.local ni .env.production al repositorio.

# Base de datos MySQL (opcional; el sitio usa data/*.json si no hay MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=tu_usuario
MYSQL_PASSWORD=tu_contraseña
MYSQL_DATABASE=cronec

# Sesión admin (OBLIGATORIO en producción: genera una clave aleatoria de 32+ caracteres)
SESSION_SECRET=clave-secreta-minimo-32-caracteres-para-firmar-cookies

# Formulario de contacto: solo si despliegas sitio estático (sin API). Con Node/Vercel se usa /api/contact.
# NEXT_PUBLIC_FORMSPREE_ID=tu_id_de_formspree
