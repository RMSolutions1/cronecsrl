# Copia este archivo a .env.local (desarrollo) o configura en tu plataforma (Vercel, etc.) en producción.
# No subas .env.local ni .env.production al repositorio.

# --- PostgreSQL (Neon) - tiene prioridad si está definido
# Pega la URL de Neon en .env.local (nunca la subas al repo). Luego ejecuta scripts/postgres/schema.sql en el SQL Editor de Neon.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# (Alternativa: POSTGRES_URL con la misma URL)

# --- MySQL (se usa si no hay DATABASE_URL ni POSTGRES_URL)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=tu_usuario
# MYSQL_PASSWORD=tu_contraseña
# MYSQL_DATABASE=cronec

# Sesión admin (OBLIGATORIO en producción: genera una clave aleatoria de 32+ caracteres)
# En producción NUNCA uses el valor por defecto del código; definir siempre esta variable.
SESSION_SECRET=clave-secreta-minimo-32-caracteres-para-firmar-cookies

# Opcional: para GET /api/db-verify en producción (diagnóstico). Si no se define, la ruta devuelve 401 en producción.
# DB_VERIFY_KEY=tu-clave-secreta-diagnostico

# Subida de imágenes en Vercel (OBLIGATORIO si desplegás en Vercel y querés subir fotos desde el dashboard).
# Creá un Blob store en el proyecto (Storage → Create → Blob) y Vercel añadirá esta variable.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Formulario de contacto en sitio ESTÁTICO (FTP): obligatorio para que el formulario funcione.
# Crea un formulario en https://formspree.io y pega aquí el ID. Ver DESPLIEGUE-ESTATICO-FTP.md.
# NEXT_PUBLIC_FORMSPREE_ID=tu_id_de_formspree

# URL pública del sitio (sitemap, OG, etc.). En Vercel puede omitirse (usa VERCEL_URL).
# NEXT_PUBLIC_SITE_URL=https://cronecsrl2026.vercel.app

# En producción, el registro de nuevos admins (/admin/registro) está deshabilitado por defecto.
# Para permitirlo, definir ALLOW_ADMIN_REGISTER=true (no recomendado en producción).
# ALLOW_ADMIN_REGISTER=true
