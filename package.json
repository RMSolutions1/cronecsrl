{
  "name": "cronec-srl-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:ftp": "powershell -ExecutionPolicy Bypass -File ./scripts/build-ftp.ps1",
    "build:static": "powershell -ExecutionPolicy Bypass -File ./scripts/build-ftp.ps1",
    "db:create-admin": "node scripts/create-admin-user.js",
    "db:migrate": "bash scripts/deploy-database.sh",
    "db:reset": "bash scripts/reset-database.sh",
    "db:setup": "node scripts/setup-database.js",
    "db:verify": "bash scripts/verify-deployment.sh",
    "deploy:production": "vercel --prod",
    "deploy:staging": "vercel --env=preview",
    "dev": "next dev",
    "dev:next": "node node_modules/next/dist/bin/next dev",
    "lint": "eslint .",
    "setup": "npm install && npm run db:setup",
    "start": "next start",
    "start:lowmem": "node --max-old-space-size=512 ./node_modules/next/dist/bin/next start",
    "start:minimal": "node --max-old-space-size=256 ./node_modules/next/dist/bin/next start",
    "db:init": "node scripts/mysql/init-db.js",
    "db:ping": "node scripts/mysql/verify-connection.js",
    "db:query": "node scripts/mysql/run-query.js",
    "db:seed-admin": "node scripts/mysql/seed-admin.js",
    "db:init-pg": "node scripts/postgres/init-db.js",
    "db:query-pg": "node scripts/postgres/query-now.js",
    "db:seed-admin-pg": "node scripts/postgres/seed-admin.js",
    "seed:admin": "node scripts/seed-admin-json.js"
  },
