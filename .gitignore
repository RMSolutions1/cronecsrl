# ============================================================================
# CRONEC SRL - .gitignore
# ============================================================================

# v0 runtime files
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# ============================================================================
# DEPENDENCIAS
# ============================================================================
node_modules/
.pnp
.pnp.js

# ============================================================================
# BUILD Y PRODUCCIÓN
# ============================================================================
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# VARIABLES DE ENTORNO (CRÍTICO - NUNCA SUBIR)
# ============================================================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ============================================================================
# DATOS SENSIBLES
# ============================================================================
