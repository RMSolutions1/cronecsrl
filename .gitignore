data/admins.json
data/*.backup.json

# ============================================================================
# LOGS Y DEBUG
# ============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# ============================================================================
# SISTEMA OPERATIVO
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# IDEs Y EDITORES
# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# ============================================================================
# PLATAFORMAS DE DEPLOY
# ============================================================================
.vercel
.netlify

# ============================================================================
# PACKAGE MANAGERS
# ============================================================================
# Usar solo npm (package-lock.json) para que Vercel no tome pnpm
pnpm-lock.yaml
yarn.lock

# ============================================================================
# TESTING Y COBERTURA
# ============================================================================
coverage/
.nyc_output/
*.lcov

# ============================================================================
# TEMPORALES Y CACHE
# ============================================================================
*.tmp
*.temp
.cache/
.turbo/
.eslintcache
.stylelintcache

# ============================================================================
# PLANES Y ARCHIVOS INTERNOS DE v0
# ============================================================================
v0_plans/
